{
  "name": "arc-pwa-ext",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "node scripts/copy-sw.js",
    "dev": "node scripts/copy-sw.js && wxt",
    "dev:firefox": "node scripts/copy-sw.js && wxt --browser firefox",
    "build": "node scripts/copy-sw.js && wxt build",
    "build:firefox": "node scripts/copy-sw.js && wxt build --browser firefox",
    "zip": "node scripts/copy-sw.js && wxt zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "wxt": "^0.19.0",
    "typescript": "^5.4.0"
  }
}
